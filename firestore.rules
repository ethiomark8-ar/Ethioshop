rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Check if user is seller
    function isSeller() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Validate Ethiopian phone number
    function isValidEthiopianPhone(phone) {
      return phone != null && phone.matches('^\\+251[0-9]{9}$');
    }
    
    // Validate ETB currency
    function isValidETBPrice(price) {
      return price != null && price >= 0;
    }
    
    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      // Users can read their own data
      // Sellers and admins can read all users
      allow read: if isOwner(userId) || isSeller() || isAdmin();
      
      // Users can create their own profile
      // Admins can create any user
      allow create: if isOwner(userId) || isAdmin();
      
      // Users can update their own profile
      // Admins can update any user
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins can delete users
      allow delete: if isAdmin();
      
      // User document structure
      // Required fields: email, role, createdAt
      // Optional fields: name, phone, photoUrl, region, city
    }
    
    // ==========================================
    // PRODUCTS COLLECTION
    // ==========================================
    match /products/{productId} {
      // All authenticated users can read products
      // Public products visible to all
      allow read: if true;
      
      // Only sellers can create products
      allow create: if isSeller() && 
        isValidETBPrice(request.resource.data.price) &&
        request.resource.data.sellerId == request.auth.uid;
      
      // Sellers can update their own products
      // Admins can update any product
      allow update: if isSeller() && 
        resource.data.sellerId == request.auth.uid || isAdmin();
      
      // Sellers can delete their own products
      // Admins can delete any product
      allow delete: if isSeller() && 
        resource.data.sellerId == request.auth.uid || isAdmin();
      
      // Product document structure
      // Required: name, price, sellerId, category, region, city
      // Optional: description, images, discountPrice, stock, rating
    }
    
    // ==========================================
    // CATEGORIES COLLECTION
    // ==========================================
    match /categories/{categoryId} {
      // Everyone can read categories
      allow read: if true;
      
      // Only admins can create, update, delete categories
      allow create, update, delete: if isAdmin();
    }
    
    // ==========================================
    // ORDERS COLLECTION
    // ==========================================
    match /orders/{orderId} {
      // Users can read their own orders
      // Sellers can read orders containing their products
      // Admins can read all orders
      allow read: if isOwner(resource.data.userId) || 
        isSeller() || isAdmin();
      
      // Authenticated users can create orders
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        isValidETBPrice(request.resource.data.total);
      
      // Users can update their own orders (limited fields)
      // Sellers can update order status for their products
      // Admins can update any order
      allow update: if isOwner(resource.data.userId) || 
        isSeller() || isAdmin();
      
      // Only admins can delete orders
      allow delete: if isAdmin();
      
      // Order document structure
      // Required: userId, products, total, status, paymentStatus
      // Optional: shippingAddress, phone, notes
    }
    
    // ==========================================
    // CART COLLECTION
    // ==========================================
    match /carts/{cartId} {
      // Users can only access their own cart
      allow read, write: if isOwner(resource.data.userId);
      
      // Allow creating cart for authenticated users
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // ==========================================
    // WISHLIST COLLECTION
    // ==========================================
    match /wishlists/{wishlistId} {
      // Users can only access their own wishlist
      allow read, write: if isOwner(resource.data.userId);
      
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // ==========================================
    // CHATS COLLECTION
    // ==========================================
    match /chats/{chatId} {
      // Users can read chats they participate in
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      
      // Authenticated users can create chats
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participants;
      
      // Participants can update chat
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      
      // No deletion allowed
      allow delete: if false;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        allow create: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
        
        allow update, delete: if false;
      }
    }
    
    // ==========================================
    // REVIEWS COLLECTION
    // ==========================================
    match /reviews/{reviewId} {
      // Everyone can read reviews
      allow read: if true;
      
      // Authenticated users can create reviews
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      
      // Users can update their own reviews
      allow update: if isOwner(resource.data.userId);
      
      // Users can delete their own reviews
      // Admins can delete any review
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // ==========================================
    // NOTIFICATIONS COLLECTION
    // ==========================================
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isOwner(resource.data.userId);
      
      // System creates notifications (via Cloud Functions)
      allow create: if false;
      
      // Users can mark as read
      allow update: if isOwner(resource.data.userId);
      
      // No deletion
      allow delete: if false;
    }
    
    // ==========================================
    // PAYMENTS COLLECTION
    // ==========================================
    match /payments/{paymentId} {
      // Users can read their own payments
      // Sellers can read payments for their orders
      // Admins can read all payments
      allow read: if isOwner(resource.data.userId) || 
        isSeller() || isAdmin();
      
      // Only Cloud Functions can create payments
      allow create: if false;
      
      // Only Cloud Functions can update payments
      allow update: if false;
      
      // No deletion
      allow delete: if false;
    }
    
    // ==========================================
    // SELLERS COLLECTION
    // ==========================================
    match /sellers/{sellerId} {
      // Everyone can read seller profiles
      allow read: if true;
      
      // Users can create seller profile for themselves
      allow create: if isOwner(request.resource.data.userId);
      
      // Sellers can update their own profile
      // Admins can update any seller profile
      allow update: if isOwner(resource.data.userId) || isAdmin();
      
      // Only admins can delete seller profiles
      allow delete: if isAdmin();
    }
    
    // ==========================================
    // REGIONS & CITIES (Read-only reference data)
    // ==========================================
    match /regions/{regionId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /cities/{cityId} {
      allow read: if true;
      allow write: if false;
    }
    
    // ==========================================
    // SETTINGS (Admin only)
    // ==========================================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ==========================================
    // ANALYTICS (Read-only for admins)
    // ==========================================
    match /analytics/{analyticsId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}