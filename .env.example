# EthioShop Environment Configuration
# Copy this file to .env and fill in your actual values

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Chapa Payment Gateway
CHAPA_SECRET_KEY=your_chapa_secret_key
CHAPA_PUBLIC_KEY=your_chapa_public_key
CHAPA_WEBHOOK_URL=https://your-domain.com/api/payment/webhook

# App Configuration
APP_NAME=EthioShop
APP_VERSION=1.0.0
APP_ENV=development

# API Configuration
API_BASE_URL=https://api.ethioshop.et
API_TIMEOUT=30000

# Firebase Storage
STORAGE_BUCKET_URL=gs://your_project.appspot.com

# Cloud Functions
CLOUD_FUNCTIONS_URL=https://your-region-your_project.cloudfunctions.net

# Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXX-X

# Social Links
FACEBOOK_URL=https://facebook.com/ethioshop
TWITTER_URL=https://twitter.com/ethioshop
INSTAGRAM_URL=https://instagram.com/ethioshop
LINKEDIN_URL=https://linkedin.com/company/ethioshop

# Support
SUPPORT_EMAIL=support@ethioshop.et
SUPPORT_PHONE=+251911234567

# Default Configuration
DEFAULT_CURRENCY=ETB
DEFAULT_LANGUAGE=en
DEFAULT_REGION=Addis Ababa

# Feature Flags
ENABLE_CHAPA_PAYMENT=true
ENABLE_OFFLINE_MODE=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_REAL_TIME_CHAT=true
ENABLE_MULTI_VENDOR=true

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Upload Limits
MAX_IMAGE_SIZE=5242880
MAX_VIDEO_SIZE=104857600
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/webm

# Delivery Configuration
DELIVERY_FEE=50.00
FREE_DELIVERY_THRESHOLD=1000.00
DELIVERY_TIME_MINUTES=30

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100