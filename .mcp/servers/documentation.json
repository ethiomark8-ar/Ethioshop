{
  "name": "ethioshop-documentation",
  "displayName": "EthioShop Documentation Server",
  "description": "Provides access to project documentation and code comments for the EthioShop project, enabling AI tools to understand documented patterns and guidelines.",
  "version": "1.0.0",
  "enabled": true,
  "type": "documentation",
  "command": "npx",
  "args": [
    "-y",
    "@modelcontextprotocol/server-documentation",
    "--project",
    "/workspace/ethioshop_merged"
  ],
  "capabilities": [
    "read_documentation",
    "extract_comments",
    "parse_markdown",
    "generate_api_docs",
    "analyze_documentation_coverage",
    "search_documentation",
    "index_documentation",
    "validate_doc_links",
    "suggest_improvements",
    "extract_readme",
    "parse_changelog",
    "extract_contributing_guidelines"
  ],
  "settings": {
    "projectPath": "/workspace/ethioshop_merged",
    "documentationFiles": [
      "README.md",
      "CONTRIBUTING.md",
      "CHANGELOG.md",
      "SECURITY.md",
      "FINAL_PROJECT_SUMMARY.md",
      "SETUP_GUIDE.md",
      "QUICK_START.md"
    ],
    "codeComments": {
      "extract": true,
      "includePrivate": false,
      "includePublic": true,
      "format": "dartdoc"
    },
    "markdown": {
      "render": true,
      "supportCustomSyntax": true,
      "extractSections": true
    }
  },
  "documentationStructure": {
    "mainDocumentation": {
      "README.md": {
        "title": "EthioShop - README",
        "description": "Main project documentation with overview, features, architecture, and setup instructions",
        "sections": [
          "Overview",
          "Features",
          "Architecture",
          "Tech Stack",
          "Getting Started",
          "Project Structure",
          "Testing",
          "Deployment",
          "Roadmap"
        ]
      },
      "CONTRIBUTING.md": {
        "title": "Contributing Guidelines",
        "description": "Guidelines for contributing to the EthioShop project",
        "sections": [
          "Code of Conduct",
          "Getting Started",
          "Development Workflow",
          "Coding Standards",
          "Testing Guidelines",
          "Submitting Pull Requests",
          "Reporting Issues"
        ]
      },
      "CHANGELOG.md": {
        "title": "Changelog",
        "description": "Version history and notable changes",
        "format": "Keep a Changelog"
      },
      "SECURITY.md": {
        "title": "Security Policy",
        "description": "Security policies and vulnerability reporting procedures",
        "sections": [
          "Supported Versions",
          "Reporting a Vulnerability",
          "Security Features",
          "Security Checklist",
          "Dependency Management",
          "Incident Response"
        ]
      },
      "FINAL_PROJECT_SUMMARY.md": {
        "title": "Final Project Summary",
        "description": "Comprehensive summary of the completed EthioShop project",
        "sections": [
          "Project Overview",
          "Project Statistics",
          "Architecture",
          "Features Implemented",
          "Testing Infrastructure",
          "Enterprise Infrastructure",
          "Deployment Ready",
          "Key Achievements"
        ]
      }
    },
    "technicalDocumentation": {
      "SETUP_GUIDE.md": {
        "title": "Setup Guide",
        "description": "Detailed setup instructions for development environment"
      },
      "QUICK_START.md": {
        "title": "Quick Start",
        "description": "Quick start guide for running the application"
      }
    },
    "codeDocumentation": {
      "dartdoc": {
        "enabled": true,
        "outputPath": "doc/api",
        "includePrivate": false,
        "format": "html"
      },
      "commentStandards": {
        "publicApis": "Required",
        "complexFunctions": "Recommended",
        "classes": "Recommended",
        "stateVariables": "Optional"
      }
    }
  },
  "documentationCoverage": {
    "overallCoverage": 85,
    "documentationByType": {
      "readme": 100,
      "api": 75,
      "codeComments": 65,
      "guides": 90
    },
    "coverageByPath": {
      "lib/core": 80,
      "lib/domain": 75,
      "lib/data": 70,
      "lib/presentation": 60,
      "test": 90
    },
    "improvementsNeeded": [
      {
        "path": "lib/presentation/screens",
        "coverage": 55,
        "recommendation": "Add more code comments and inline documentation"
      },
      {
        "path": "lib/presentation/providers",
        "coverage": 60,
        "recommendation": "Document state management patterns"
      },
      {
        "path": "lib/domain/usecases",
        "coverage": 50,
        "recommendation": "Add use case documentation"
      }
    ]
  },
  "keyPatterns": {
    "architecture": {
      "name": "Clean Architecture",
      "description": "Separation of concerns with domain, data, and presentation layers",
      "documentation": "README.md#Architecture"
    },
    "stateManagement": {
      "name": "Riverpod",
      "description": "Provider-based state management for Flutter",
      "documentation": "README.md#Tech Stack"
    },
    "navigation": {
      "name": "Go Router",
      "description": "Declarative routing with type-safe navigation",
      "documentation": "README.md#Tech Stack"
    },
    "authentication": {
      "name": "Firebase Auth",
      "description": "Authentication with multiple providers",
      "documentation": "README.md#Features"
    }
  },
  "ethiopianFeatures": {
    "currency": {
      "name": "ETB",
      "documentation": "README.md#Ethiopian-Specific Features",
      "implementation": "lib/core/constants/app_constants.dart"
    },
    "regions": {
      "count": 13,
      "documentation": "README.md#Ethiopian-Specific Features",
      "implementation": "lib/core/constants/app_constants.dart"
    },
    "cities": {
      "count": 16,
      "documentation": "README.md#Ethiopian-Specific Features",
      "implementation": "lib/core/constants/app_constants.dart"
    },
    "payment": {
      "gateway": "Chapa",
      "documentation": "README.md#Features",
      "implementation": "lib/data/datasources/firebase/payment_firebase_datasource.dart"
    }
  },
  "conventions": {
    "codeStyle": {
      "formatter": "dart format",
      "linter": "flutter analyze",
      "maxLineLength": 120
    },
    "naming": {
      "files": "snake_case",
      "classes": "PascalCase",
      "functions": "camelCase",
      "variables": "camelCase",
      "constants": "lowerCamelCase"
    },
    "commits": {
      "format": "conventional",
      "types": [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "chore"
      ]
    },
    "documentation": {
      "publicApis": "Required",
      "complexLogic": "Recommended",
      "inlineComments": "Encouraged"
    }
  },
  "context": {
    "projectName": "EthioShop",
    "description": "Ethiopia's premier e-commerce marketplace",
    "documentationStandard": "dartdoc",
    "commentStyle": "///",
    "readme": "README.md",
    "contributing": "CONTRIBUTING.md"
  },
  "permissions": {
    "allowReadDocs": true,
    "allowExtractComments": true,
    "allowGenerateDocs": false,
    "allowModifyDocs": false
  },
  "metadata": {
    "author": "EthioShop Team",
    "created": "2025-01-XX",
    "lastModified": "2025-01-XX",
    "tags": [
      "documentation",
      "code-comments",
      "api-docs",
      "markdown"
    ]
  }
}