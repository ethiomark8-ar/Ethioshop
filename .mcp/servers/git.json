{
  "name": "ethioshop-git",
  "displayName": "EthioShop Git",
  "description": "Provides Git operations and version control context for the EthioShop project, enabling AI tools to understand code evolution and changes.",
  "version": "1.0.0",
  "enabled": true,
  "type": "git",
  "command": "npx",
  "args": [
    "-y",
    "@modelcontextprotocol/server-git",
    "--repository",
    "/workspace/ethioshop_merged"
  ],
  "capabilities": [
    "get_commit_history",
    "get_branch_list",
    "get_current_branch",
    "get_diff",
    "get_file_blame",
    "get_commit_details",
    "get_staged_files",
    "get_unstaged_files",
    "get_file_history",
    "search_commits",
    "get_repository_status",
    "get_remote_info"
  ],
  "settings": {
    "repositoryPath": "/workspace/ethioshop_merged",
    "maxCommitHistory": 100,
    "maxDiffSize": 524288,
    "includeMergeCommits": true,
    "includeAuthorInfo": true,
    "includeTimestamp": true,
    "enableBlame": true,
    "fileHistoryLimit": 50,
    "commitMessageFormat": "full",
    "diffContextLines": 3
  },
  "context": {
    "defaultBranch": "main",
    "protectedBranches": [
      "main",
      "develop",
      "production"
    ],
    "commitConventions": {
      "types": [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "chore"
      ],
      "scopeRequired": false,
      "bodyRequired": false,
      "footerRequired": false
    },
    "team": {
      "name": "EthioShop Development Team",
      "size": "medium"
    }
  },
  "branches": {
    "main": {
      "description": "Production branch",
      "protection": "strict",
      "requiresReview": true,
      "requiresTests": true
    },
    "develop": {
      "description": "Development branch",
      "protection": "moderate",
      "requiresReview": true,
      "requiresTests": true
    },
    "feature/*": {
      "description": "Feature branches",
      "protection": "none",
      "requiresReview": false,
      "requiresTests": true
    },
    "fix/*": {
      "description": "Bug fix branches",
      "protection": "none",
      "requiresReview": true,
      "requiresTests": true
    }
  },
  "permissions": {
    "allowRead": true,
    "allowWrite": true,
    "allowPush": false,
    "allowForcePush": false,
    "allowDeleteBranch": false
  },
  "metadata": {
    "author": "EthioShop Team",
    "created": "2025-01-XX",
    "lastModified": "2025-01-XX",
    "tags": [
      "git",
      "version-control",
      "vcs",
      "code-evolution"
    ]
  }
}