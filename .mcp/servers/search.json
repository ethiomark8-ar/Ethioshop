{
  "name": "ethioshop-search",
  "displayName": "EthioShop Code Search",
  "description": "Provides fast code search and indexing capabilities for the EthioShop Flutter codebase, enabling AI tools to quickly locate code patterns and implementations.",
  "version": "1.0.0",
  "enabled": true,
  "type": "search",
  "command": "npx",
  "args": [
    "-y",
    "@modelcontextprotocol/server-search",
    "--root",
    "."
  ],
  "capabilities": [
    "full_text_search",
    "symbol_search",
    "regex_search",
    "file_path_search",
    "content_search",
    "class_search",
    "function_search",
    "variable_search",
    "import_search",
    "dependency_search",
    "grep_search",
    "ripgrep_search"
  ],
  "settings": {
    "rootPath": ".",
    "excludes": [
      "build/**",
      ".dart_tool/**",
      ".git/**",
      ".firebase/**",
      "node_modules/**",
      "*.generated.dart",
      "*.lock"
    ],
    "includes": [
      "lib/**/*.dart",
      "test/**/*.dart",
      "web/**/*",
      "pubspec.yaml"
    ],
    "indexing": {
      "enabled": true,
      "autoIndex": true,
      "indexInterval": 300000,
      "incrementalIndexing": true,
      "indexSymbols": true,
      "indexContent": true,
      "indexImports": true
    },
    "search": {
      "maxResults": 100,
      "highlightMatches": true,
      "contextLines": 3,
      "caseSensitive": false,
      "wholeWord": false,
      "regexSupport": true,
      "fuzzySearch": true,
      "fuzzyThreshold": 0.6
    },
    "performance": {
      "cacheSize": 52428800,
      "maxFileSize": 10485760,
      "parallelSearches": 4,
      "searchTimeout": 30000
    }
  },
  "indexedResources": {
    "dart_files": {
      "path": "lib/**/*.dart",
      "description": "All Dart source files",
      "patterns": [
        "*.dart"
      ]
    },
    "test_files": {
      "path": "test/**/*.dart",
      "description": "All test files",
      "patterns": [
        "*_test.dart"
      ]
    },
    "widgets": {
      "path": "lib/presentation/widgets/**/*.dart",
      "description": "Flutter widget components",
      "patterns": [
        "*_widget.dart",
        "*widget*.dart"
      ]
    },
    "screens": {
      "path": "lib/presentation/screens/**/*.dart",
      "description": "Flutter screen components",
      "patterns": [
        "*_screen.dart"
      ]
    },
    "providers": {
      "path": "lib/presentation/providers/**/*.dart",
      "description": "Riverpod state management providers",
      "patterns": [
        "*_provider.dart"
      ]
    },
    "models": {
      "path": "lib/data/models/**/*.dart",
      "description": "Data models",
      "patterns": [
        "*_model.dart"
      ]
    },
    "entities": {
      "path": "lib/domain/entities/**/*.dart",
      "description": "Domain entities",
      "patterns": [
        "*.dart"
      ]
    },
    "repositories": {
      "path": "lib/data/repositories/**/*.dart",
      "description": "Repository implementations",
      "patterns": [
        "*_repository_impl.dart"
      ]
    },
    "usecases": {
      "path": "lib/domain/usecases/**/*.dart",
      "description": "Business logic use cases",
      "patterns": [
        "*_usecase.dart"
      ]
    },
    "constants": {
      "path": "lib/core/constants/**/*.dart",
      "description": "Application constants",
      "patterns": [
        "*.dart"
      ]
    }
  },
  "symbolTypes": [
    "class",
    "mixin",
    "extension",
    "function",
    "method",
    "constructor",
    "variable",
    "field",
    "parameter",
    "typedef",
    "enum",
    "annotation"
  ],
  "context": {
    "language": "Dart",
    "framework": "Flutter",
    "stateManagement": "Riverpod",
    "navigation": "Go Router",
    "backend": "Firebase"
  },
  "permissions": {
    "allowRead": true,
    "allowSearch": true,
    "allowIndex": true,
    "allowExport": false
  },
  "metadata": {
    "author": "EthioShop Team",
    "created": "2025-01-XX",
    "lastModified": "2025-01-XX",
    "tags": [
      "search",
      "indexing",
      "code-search",
      "ripgrep"
    ]
  }
}