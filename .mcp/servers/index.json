{
  "name": "ethioshop-index",
  "displayName": "EthioShop Master Index",
  "description": "Master index server that aggregates all MCP servers and provides unified access to the entire EthioShop codebase, documentation, and project context.",
  "version": "1.0.0",
  "enabled": true,
  "type": "index",
  "command": "npx",
  "args": [
    "-y",
    "@modelcontextprotocol/server-index",
    "--root",
    "."
  ],
  "capabilities": [
    "unified_search",
    "cross_server_query",
    "aggregate_results",
    "context_aware_search",
    "semantic_search",
    "code_intelligence",
    "project_overview",
    "dependency_mapping",
    "file_relationships",
    "code_graph",
    "knowledge_graph"
  ],
  "settings": {
    "rootPath": ".",
    "indexAll": true,
    "realTimeIndexing": true,
    "incrementalUpdates": true,
    "semanticSearch": true,
    "crossReference": true
  },
  "servers": [
    {
      "name": "filesystem",
      "configFile": ".mcp/servers/filesystem.json",
      "priority": 1,
      "enabled": true
    },
    {
      "name": "git",
      "configFile": ".mcp/servers/git.json",
      "priority": 2,
      "enabled": true
    },
    {
      "name": "search",
      "configFile": ".mcp/servers/search.json",
      "priority": 3,
      "enabled": true
    },
    {
      "name": "dart",
      "configFile": ".mcp/servers/dart.json",
      "priority": 4,
      "enabled": true
    },
    {
      "name": "firebase",
      "configFile": ".mcp/servers/firebase.json",
      "priority": 5,
      "enabled": true
    },
    {
      "name": "testing",
      "configFile": ".mcp/servers/testing.json",
      "priority": 6,
      "enabled": true
    },
    {
      "name": "documentation",
      "configFile": ".mcp/servers/documentation.json",
      "priority": 7,
      "enabled": true
    }
  ],
  "projectContext": {
    "name": "EthioShop",
    "type": "Flutter E-commerce Marketplace",
    "version": "1.0.0",
    "status": "Production Ready",
    "completion": 95,
    "description": "Ethiopia's premier e-commerce marketplace with multi-vendor support, Firebase integration, and Ethiopian-specific features.",
    "location": "."
  },
